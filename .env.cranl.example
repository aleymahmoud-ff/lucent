# === CranL Deployment Environment ===
# These values are injected by CranL managed services or set manually.
# Copy relevant entries into the CranL app environment via:
#   cranl apps env set <app-id> KEY=value ...
# Never commit real secrets to version control.

# -----------------------------------------------------------------------
# Database (injected automatically by: cranl db create --type pg --inject)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# -----------------------------------------------------------------------
# Redis (injected automatically by: cranl db create --type redis --inject)
# -----------------------------------------------------------------------
REDIS_URL=redis://default:pass@host:6379

# -----------------------------------------------------------------------
# S3 Storage (from CranL Storage Bucket settings in the dashboard)
# CDN endpoint format: https://storage-{bucket-name}.cranl.net
# -----------------------------------------------------------------------
S3_BUCKET=lucent-data
S3_ENDPOINT_URL=https://storage-lucent-data.cranl.net
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1
STORAGE_BACKEND=s3

# -----------------------------------------------------------------------
# Security
# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate SECRET_KEY with:      python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------
ENCRYPTION_KEY=generate-a-fernet-key-here
SECRET_KEY=generate-a-random-secret-key

# -----------------------------------------------------------------------
# App Config
# -----------------------------------------------------------------------
BASE_PATH=/lucent
APP_ENV=production
DEBUG=False
NEXT_PUBLIC_API_URL=https://your-backend-app.cranl.app/api/v1
CORS_ORIGINS=https://your-frontend-app.cranl.app

# -----------------------------------------------------------------------
# Stack Auth (from Stack Auth dashboard)
# -----------------------------------------------------------------------
STACK_PROJECT_ID=your-stack-project-id
STACK_PUBLISHABLE_CLIENT_KEY=your-publishable-client-key
STACK_SECRET_SERVER_KEY=your-secret-server-key
